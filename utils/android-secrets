#!/usr/bin/env bash
set -euo pipefail

# ===================================
# METADATA
# ===================================
SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_NAME
readonly VERSION="1.1.0"
readonly SCRIPT_DESCRIPTION="Generate Android signing secrets from a keystore"

# ===================================
# COLORS
# ===================================
if [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]]; then
	readonly RED=$'\033[0;31m'
	readonly GREEN=$'\033[0;32m'
	readonly YELLOW=$'\033[0;33m'
	readonly BLUE=$'\033[0;34m'
	readonly MAGENTA=$'\033[0;35m'
	readonly BOLD=$'\033[1m'
	readonly NC=$'\033[0m'
else
	readonly RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' BOLD='' NC=''
fi

# ===================================
# CONFIGURATION
# ===================================
DEBUG=false
QUIET=false

KEYSTORE_PATH=""
KEY_ALIAS=""
PREFIX="ANDROID"
OUTPUT_FILE=""
PASSPHRASE_LENGTH=40
GENERATE_ALIAS=false

# ===================================
# LOGGING FUNCTIONS
# ===================================
log() {
	if [[ "$QUIET" != true ]]; then
		printf "${BLUE}▶${NC} %s\n" "$*"
	fi
}
warn() { printf "${YELLOW}⚠${NC} %s\n" "$*" >&2; }
error() { printf "${RED}✗${NC} %s\n" "$*" >&2; }
success() {
	if [[ "$QUIET" != true ]]; then
		printf "${GREEN}✓${NC} %s\n" "$*"
	fi
}
debug() {
	if [[ "$DEBUG" == true ]]; then
		printf "${MAGENTA}⚈${NC} DEBUG: %s\n" "$*" >&2
	fi
}
die() {
	error "$*"
	exit 1
}

# ===================================
# UTILITIES
# ===================================
require_cmd() {
	command -v "$1" >/dev/null 2>&1 || die "'$1' is not installed or not in PATH."
}

validate_common() {
	[[ "$PREFIX" =~ ^[A-Z][A-Z0-9_]*$ ]] || die "Invalid --prefix '$PREFIX' (use uppercase letters, numbers, underscores; must start with a letter)"
	[[ "$PASSPHRASE_LENGTH" =~ ^[0-9]+$ ]] || die "Invalid --passphrase-length '$PASSPHRASE_LENGTH' (must be numeric)"
	((PASSPHRASE_LENGTH >= 16)) || die "--passphrase-length must be at least 16"
	((PASSPHRASE_LENGTH <= 256)) || die "--passphrase-length must be at most 256"
}

validate_generate_inputs() {
	[[ -n "$KEYSTORE_PATH" ]] || die "Missing required flag: --keystore"
	[[ -f "$KEYSTORE_PATH" ]] || die "Keystore file not found: $KEYSTORE_PATH"
	[[ -r "$KEYSTORE_PATH" ]] || die "Keystore file is not readable: $KEYSTORE_PATH"
	[[ -s "$KEYSTORE_PATH" ]] || die "Keystore file is empty: $KEYSTORE_PATH"
}

encode_keystore_base64() {
	local path="$1"
	if base64 --help >/dev/null 2>&1; then
		base64 -w 0 "$path"
	else
		base64 <"$path" | tr -d '\n'
	fi
}

generate_safe_passphrase() {
	local length="$1"
	local charset='A-Za-z0-9._-'
	local passphrase=""

	while ((${#passphrase} < length)); do
		passphrase+=$(LC_ALL=C tr -dc "$charset" </dev/urandom 2>/dev/null | head -c "$((length - ${#passphrase}))")
	done

	printf "%s" "$passphrase"
}

generate_safe_alias() {
	local alias_len=16
	local suffix=""

	while ((${#suffix} < alias_len)); do
		suffix+=$(LC_ALL=C tr -dc 'a-z0-9' </dev/urandom 2>/dev/null | head -c "$((alias_len - ${#suffix}))")
	done

	printf "release_%s" "$suffix"
}

resolve_alias_value() {
	local current_alias="$1"
	local keystore_path="$2"
	local keystore_password="$3"

	if [[ -n "$current_alias" ]]; then
		printf "%s" "$current_alias"
		return 0
	fi

	if [[ -n "${ANDROID_KEY_ALIAS:-}" ]]; then
		printf "%s" "$ANDROID_KEY_ALIAS"
		return 0
	fi

	require_cmd keytool

	local aliases=()
	while IFS= read -r line; do
		[[ -n "$line" ]] && aliases+=("$line")
	done < <(
		keytool -list -keystore "$keystore_path" -storepass "$keystore_password" 2>/dev/null \
			| awk -F',' '/,/{gsub(/^[[:space:]]+|[[:space:]]+$/, "", $1); if ($1 != "") print $1}'
	)

	local count="${#aliases[@]}"
	if ((count == 1)); then
		log "Using detected key alias: ${aliases[0]}"
		printf "%s" "${aliases[0]}"
		return 0
	fi

	if ((count == 0)); then
		die "Could not detect alias from keystore. Provide --alias or ANDROID_KEY_ALIAS."
	fi

	die "Multiple aliases found in keystore. Provide --alias or ANDROID_KEY_ALIAS."
}

emit_output() {
	local keystore_base64="$1"
	local keystore_password="$2"
	local key_alias="$3"
	local key_password="$4"
	local output_lines

	output_lines=$(
		cat <<EOF
${PREFIX}_KEYSTORE_BASE64=$keystore_base64
${PREFIX}_KEYSTORE_PASSWORD=$keystore_password
${PREFIX}_KEY_ALIAS=$key_alias
${PREFIX}_KEY_PASSWORD=$key_password
EOF
	)

	if [[ -n "$OUTPUT_FILE" ]]; then
		printf "%s\n" "$output_lines" >"$OUTPUT_FILE"
		success "Secrets written to $OUTPUT_FILE"
	else
		printf "%s\n" "$output_lines"
	fi
}

# ===================================
# COMMANDS
# ===================================
cmd_help() {
	cat <<EOF
${BOLD}${SCRIPT_NAME}${NC} - ${SCRIPT_DESCRIPTION}

${BOLD}USAGE:${NC}
  $SCRIPT_NAME [OPTIONS] COMMAND

${BOLD}COMMANDS:${NC}
  ${GREEN}generate${NC}                Generate signing secrets from a keystore
  ${GREEN}passphrases${NC}             Generate safe password secrets for CI
  ${GREEN}help${NC}                    Show this help message
  ${GREEN}version${NC}                 Show script version

${BOLD}OPTIONS:${NC}
  ${YELLOW}--keystore${NC} <path>                Path to Android keystore file (required for generate)
  ${YELLOW}--alias${NC} <name>                   Android key alias (optional if detectable)
  ${YELLOW}--passphrase-length${NC} <n>          Generated password length (default: 40)
  ${YELLOW}--generate-alias${NC}                 With 'passphrases', generate key alias too
  ${YELLOW}--prefix${NC} <name>                  Secret key prefix (default: ANDROID)
  ${YELLOW}--out${NC} <path>                     Write output to file instead of stdout
  ${YELLOW}-q, --quiet${NC}                      Minimize output
  ${YELLOW}-d, --debug${NC}                      Enable debug logs
  ${YELLOW}-h, --help${NC}                       Show help
  ${YELLOW}-v, --version${NC}                    Show version

${BOLD}ENV FALLBACKS:${NC}
  ANDROID_KEY_ALIAS

${BOLD}EXAMPLES:${NC}
  # Build full signing secret set from a keystore (passwords auto-generated)
  $SCRIPT_NAME generate --keystore ./release.keystore --alias release_key

  # Use custom prefix
  $SCRIPT_NAME generate --keystore ./release.keystore --alias release_key --prefix MOBILE

  # Generate strong passwords for GitHub Secrets
  $SCRIPT_NAME passphrases --generate-alias

  # Generate only passwords with custom length
  $SCRIPT_NAME passphrases --passphrase-length 64
EOF
}

cmd_version() {
	printf "%s %s\n" "$SCRIPT_NAME" "$VERSION"
}

cmd_generate() {
	require_cmd base64
	validate_common
	validate_generate_inputs

	log "Generating Android signing secrets from keystore"
	debug "Keystore path: $KEYSTORE_PATH"
	debug "Alias: $KEY_ALIAS"
	debug "Prefix: $PREFIX"
	[[ -n "$OUTPUT_FILE" ]] && debug "Output file: $OUTPUT_FILE"

	local keystore_password key_password keystore_base64 effective_alias
	keystore_password="$(generate_safe_passphrase "$PASSPHRASE_LENGTH")"

	effective_alias="$(resolve_alias_value "$KEY_ALIAS" "$KEYSTORE_PATH" "$keystore_password")"

	key_password="$(generate_safe_passphrase "$PASSPHRASE_LENGTH")"

	keystore_base64="$(encode_keystore_base64 "$KEYSTORE_PATH")"
	[[ -n "$keystore_base64" ]] || die "Encoded keystore is empty. Check file contents: $KEYSTORE_PATH"
	emit_output "$keystore_base64" "$keystore_password" "$effective_alias" "$key_password"

	success "Secrets generated successfully"
}

cmd_passphrases() {
	validate_common

	local keystore_password key_password alias_value=""
	keystore_password="$(generate_safe_passphrase "$PASSPHRASE_LENGTH")"
	key_password="$(generate_safe_passphrase "$PASSPHRASE_LENGTH")"

	if [[ "$GENERATE_ALIAS" == true ]]; then
		if [[ -n "$KEY_ALIAS" ]]; then
			alias_value="$KEY_ALIAS"
		elif [[ -n "${ANDROID_KEY_ALIAS:-}" ]]; then
			alias_value="$ANDROID_KEY_ALIAS"
		else
			alias_value="$(generate_safe_alias)"
		fi
	fi

	if [[ -n "$OUTPUT_FILE" ]]; then
		{
			printf "%s_KEYSTORE_PASSWORD=%s\n" "$PREFIX" "$keystore_password"
			printf "%s_KEY_PASSWORD=%s\n" "$PREFIX" "$key_password"
			if [[ -n "$alias_value" ]]; then
				printf "%s_KEY_ALIAS=%s\n" "$PREFIX" "$alias_value"
			fi
		} >"$OUTPUT_FILE"
		success "Passphrases written to $OUTPUT_FILE"
	else
		printf "%s_KEYSTORE_PASSWORD=%s\n" "$PREFIX" "$keystore_password"
		printf "%s_KEY_PASSWORD=%s\n" "$PREFIX" "$key_password"
		if [[ -n "$alias_value" ]]; then
			printf "%s_KEY_ALIAS=%s\n" "$PREFIX" "$alias_value"
		fi
	fi
}

# ===================================
# ARGUMENT PARSING
# ===================================
parse_arguments() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--keystore)
			KEYSTORE_PATH="${2:-}"
			[[ -n "$KEYSTORE_PATH" ]] || die "Missing value for --keystore"
			shift 2
			;;
		--alias)
			KEY_ALIAS="${2:-}"
			[[ -n "$KEY_ALIAS" ]] || die "Missing value for --alias"
			shift 2
			;;
		--passphrase-length)
			PASSPHRASE_LENGTH="${2:-}"
			[[ -n "$PASSPHRASE_LENGTH" ]] || die "Missing value for --passphrase-length"
			shift 2
			;;
		--generate-alias)
			GENERATE_ALIAS=true
			shift
			;;
		--prefix)
			PREFIX="${2:-}"
			[[ -n "$PREFIX" ]] || die "Missing value for --prefix"
			shift 2
			;;
		--out)
			OUTPUT_FILE="${2:-}"
			[[ -n "$OUTPUT_FILE" ]] || die "Missing value for --out"
			shift 2
			;;
		-q | --quiet)
			QUIET=true
			shift
			;;
		-d | --debug)
			DEBUG=true
			shift
			;;
		-h | --help)
			cmd_help
			exit 0
			;;
		-v | --version)
			cmd_version
			exit 0
			;;
		-*)
			die "Unknown option: $1"
			;;
		*)
			shift
			;;
		esac
	done
}

# ===================================
# MAIN
# ===================================
main() {
	local command="${1:-help}"
	parse_arguments "$@"

	case "$command" in
	generate)
		cmd_generate
		;;
	passphrases)
		cmd_passphrases
		;;
	help)
		cmd_help
		;;
	version)
		cmd_version
		;;
	*)
		die "Unknown command: '$command'. Use '$SCRIPT_NAME help'."
		;;
	esac
}

main "$@"
