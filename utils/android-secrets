#!/usr/bin/env bash
set -euo pipefail

# ===================================
# METADATA
# ===================================
SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_NAME
readonly VERSION="2.0.0"
readonly SCRIPT_DESCRIPTION="Generate Android keystore and export signing secrets"

# ===================================
# COLORS
# ===================================
if [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]]; then
	readonly RED=$'\033[0;31m'
	readonly GREEN=$'\033[0;32m'
	readonly YELLOW=$'\033[0;33m'
	readonly BLUE=$'\033[0;34m'
	readonly BOLD=$'\033[1m'
	readonly NC=$'\033[0m'
else
	readonly RED='' GREEN='' YELLOW='' BLUE='' BOLD='' NC=''
fi

# ===================================
# CONFIGURATION
# ===================================
QUIET=false
FORCE=false
COPY_TO_CLIPBOARD=false

KEYSTORE_PATH="${KEYSTORE_PATH:-release.keystore}"
OUTPUT_FILE=""
PASSWORD_LENGTH=40
ALIAS_LENGTH=16
DNAME="${DNAME:-CN=DigitalDreams, OU=Android, O=DigitalDreams, L=San Salvador, ST=San Salvador, C=SV}"
KEY_ALIAS="${ANDROID_KEY_ALIAS:-}"
KEYSTORE_PASSWORD="${ANDROID_KEYSTORE_PASSWORD:-}"

# ===================================
# LOGGING FUNCTIONS
# ===================================
log() {
	if [[ "$QUIET" != true ]]; then
		printf "${BLUE}▶${NC} %s\n" "$*"
	fi
}
warn() { printf "${YELLOW}⚠${NC} %s\n" "$*" >&2; }
error() { printf "${RED}✗${NC} %s\n" "$*" >&2; }
success() {
	if [[ "$QUIET" != true ]]; then
		printf "${GREEN}✓${NC} %s\n" "$*"
	fi
}
die() {
	error "$*"
	exit 1
}

# ===================================
# UTILITIES
# ===================================
require_cmd() {
	command -v "$1" >/dev/null 2>&1 || die "'$1' is not installed or not in PATH."
}

generate_random_string() {
	local length="$1"
	local charset="$2"
	local out=""

	while ((${#out} < length)); do
		out+=$(LC_ALL=C tr -dc "$charset" </dev/urandom 2>/dev/null | head -c "$((length - ${#out}))")
	done

	printf "%s" "$out"
}

generate_password() {
	generate_random_string "$PASSWORD_LENGTH" 'A-Za-z0-9._-'
}

generate_alias() {
	printf "release_%s" "$(generate_random_string "$ALIAS_LENGTH" 'a-z0-9')"
}

encode_keystore_base64() {
	local path="$1"
	if base64 --help >/dev/null 2>&1; then
		base64 -w 0 "$path"
	else
		base64 <"$path" | tr -d '\n'
	fi
}

validate_inputs() {
	[[ "$PASSWORD_LENGTH" =~ ^[0-9]+$ ]] || die "Invalid --password-length '$PASSWORD_LENGTH' (must be numeric)"
	[[ "$ALIAS_LENGTH" =~ ^[0-9]+$ ]] || die "Invalid --alias-length '$ALIAS_LENGTH' (must be numeric)"
	((PASSWORD_LENGTH >= 16)) || die "--password-length must be at least 16"
	((PASSWORD_LENGTH <= 256)) || die "--password-length must be at most 256"
	((ALIAS_LENGTH >= 4)) || die "--alias-length must be at least 4"
	((ALIAS_LENGTH <= 64)) || die "--alias-length must be at most 64"

	if [[ -e "$KEYSTORE_PATH" ]] && [[ "$FORCE" != true ]]; then
		die "Keystore already exists at '$KEYSTORE_PATH'. Use --force to overwrite."
	fi

	if [[ -n "$OUTPUT_FILE" ]] && [[ -e "$OUTPUT_FILE" ]] && [[ "$FORCE" != true ]]; then
		die "Output file already exists at '$OUTPUT_FILE'. Use --force to overwrite."
	fi
}

validate_keystore_inputs() {
	[[ -f "$KEYSTORE_PATH" ]] || die "Keystore not found: $KEYSTORE_PATH"
	[[ -r "$KEYSTORE_PATH" ]] || die "Keystore is not readable: $KEYSTORE_PATH"
	[[ -s "$KEYSTORE_PATH" ]] || die "Keystore is empty: $KEYSTORE_PATH"
	[[ -n "$KEY_ALIAS" ]] || die "Missing key alias. Set --alias or ANDROID_KEY_ALIAS."
	[[ -n "$KEYSTORE_PASSWORD" ]] || die "Missing keystore password. Set --keystore-password or ANDROID_KEYSTORE_PASSWORD."
}

emit_output() {
	local payload="$1"

	if [[ -n "$OUTPUT_FILE" ]]; then
		printf "%s\n" "$payload" >"$OUTPUT_FILE"
		success "Secrets written to $OUTPUT_FILE"
	fi

	if [[ "$COPY_TO_CLIPBOARD" == true ]]; then
		printf "%s" "$payload" | xclip -selection clipboard
		success "Secrets copied to clipboard"
	fi

	if [[ -z "$OUTPUT_FILE" ]] && [[ "$COPY_TO_CLIPBOARD" != true ]]; then
		printf "%s\n" "$payload"
		success "Secrets printed to stdout"
	fi
}

# ===================================
# COMMANDS
# ===================================
cmd_help() {
	cat <<EOF
${BOLD}${SCRIPT_NAME}${NC} - ${SCRIPT_DESCRIPTION}

${BOLD}USAGE:${NC}
  $SCRIPT_NAME [OPTIONS] COMMAND
  $SCRIPT_NAME [OPTIONS]

${BOLD}COMMANDS:${NC}
  ${GREEN}generate${NC}                Generate keystore + secrets (default command)
  ${GREEN}validate${NC}                Validate existing keystore credentials
  ${GREEN}help${NC}                    Show this help message
  ${GREEN}version${NC}                 Show script version

${BOLD}OPTIONS:${NC}
  ${YELLOW}--keystore${NC} <path>               Keystore output path (default: release.keystore)
  ${YELLOW}--alias${NC} <name>                  Key alias (or ANDROID_KEY_ALIAS)
  ${YELLOW}--keystore-password${NC} <value>     Keystore password (or ANDROID_KEYSTORE_PASSWORD)
  ${YELLOW}--out${NC} <path>                    Write secrets to a file
  ${YELLOW}--xclip${NC}                         Copy secrets to clipboard using xclip
  ${YELLOW}--password-length${NC} <n>           Password length for generated password (default: 40)
  ${YELLOW}--alias-length${NC} <n>              Random alias suffix length (default: 16)
  ${YELLOW}--dname${NC} <value>                 X.500 distinguished name for keytool
  ${YELLOW}--force${NC}                         Overwrite existing keystore/output file
  ${YELLOW}-q, --quiet${NC}                     Minimize output
  ${YELLOW}-h, --help${NC}                      Show help
  ${YELLOW}-v, --version${NC}                   Show version

${BOLD}ENV INPUTS:${NC}
  ANDROID_KEYSTORE_PASSWORD      If set, uses this password instead of random
  ANDROID_KEY_ALIAS              If set, uses this alias instead of random
  KEYSTORE_PATH                  Fallback keystore path
  DNAME                          Fallback distinguished name

${BOLD}OUTPUT FIELDS:${NC}
  ANDROID_KEYSTORE_BASE64
  ANDROID_KEYSTORE_PATH
  ANDROID_KEYSTORE_PASSWORD
  ANDROID_KEY_ALIAS

${BOLD}EXAMPLES:${NC}
  $SCRIPT_NAME generate --keystore ./release.keystore --out ./android-secrets.env
  $SCRIPT_NAME validate --keystore ./release.keystore --alias release_key --keystore-password '\$ANDROID_KEYSTORE_PASSWORD'
  $SCRIPT_NAME --xclip
EOF
}

cmd_version() {
	printf "%s %s\n" "$SCRIPT_NAME" "$VERSION"
}

cmd_generate() {
	require_cmd keytool
	require_cmd base64
	if [[ "$COPY_TO_CLIPBOARD" == true ]]; then
		require_cmd xclip
	fi

	validate_inputs

	local keystore_password key_alias keystore_base64 payload
	keystore_password="${KEYSTORE_PASSWORD:-$(generate_password)}"
	key_alias="${KEY_ALIAS:-$(generate_alias)}"

	log "Generating Android keystore at $KEYSTORE_PATH"
	keytool -genkeypair \
		-v \
		-keystore "$KEYSTORE_PATH" \
		-storetype PKCS12 \
		-alias "$key_alias" \
		-storepass "$keystore_password" \
		-keypass "$keystore_password" \
		-keyalg RSA \
		-keysize 2048 \
		-validity 10000 \
		-dname "$DNAME"

	keystore_base64="$(encode_keystore_base64 "$KEYSTORE_PATH")"
	[[ -n "$keystore_base64" ]] || die "Encoded keystore is empty: $KEYSTORE_PATH"

	payload=$(
		cat <<EOF
ANDROID_KEYSTORE_BASE64=$keystore_base64
ANDROID_KEYSTORE_PATH=$KEYSTORE_PATH
ANDROID_KEYSTORE_PASSWORD=$keystore_password
ANDROID_KEY_ALIAS=$key_alias
EOF
	)

	emit_output "$payload"
}

cmd_validate() {
	require_cmd keytool
	validate_keystore_inputs

	log "Validating keystore '$KEYSTORE_PATH' with alias '$KEY_ALIAS'"
	keytool -list -v \
		-keystore "$KEYSTORE_PATH" \
		-storetype PKCS12 \
		-alias "$KEY_ALIAS" \
		-storepass "$KEYSTORE_PASSWORD" >/dev/null

	success "Keystore validation succeeded"
}

# ===================================
# ARGUMENT PARSING
# ===================================
parse_arguments() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--keystore)
			KEYSTORE_PATH="${2:-}"
			[[ -n "$KEYSTORE_PATH" ]] || die "Missing value for --keystore"
			shift 2
			;;
		--out)
			OUTPUT_FILE="${2:-}"
			[[ -n "$OUTPUT_FILE" ]] || die "Missing value for --out"
			shift 2
			;;
		--alias)
			KEY_ALIAS="${2:-}"
			[[ -n "$KEY_ALIAS" ]] || die "Missing value for --alias"
			shift 2
			;;
		--keystore-password)
			KEYSTORE_PASSWORD="${2:-}"
			[[ -n "$KEYSTORE_PASSWORD" ]] || die "Missing value for --keystore-password"
			shift 2
			;;
		--xclip)
			COPY_TO_CLIPBOARD=true
			shift
			;;
		--password-length)
			PASSWORD_LENGTH="${2:-}"
			[[ -n "$PASSWORD_LENGTH" ]] || die "Missing value for --password-length"
			shift 2
			;;
		--alias-length)
			ALIAS_LENGTH="${2:-}"
			[[ -n "$ALIAS_LENGTH" ]] || die "Missing value for --alias-length"
			shift 2
			;;
		--dname)
			DNAME="${2:-}"
			[[ -n "$DNAME" ]] || die "Missing value for --dname"
			shift 2
			;;
		--force)
			FORCE=true
			shift
			;;
		-q | --quiet)
			QUIET=true
			shift
			;;
		-h | --help)
			cmd_help
			exit 0
			;;
		-v | --version)
			cmd_version
			exit 0
			;;
		*)
			shift
			;;
		esac
	done
}

# ===================================
# MAIN
# ===================================
main() {
	local command="${1:-help}"
	parse_arguments "$@"

	case "$command" in
	generate)
		cmd_generate
		;;
	validate)
		cmd_validate
		;;
	help)
		cmd_help
		;;
	version)
		cmd_version
		;;
	*)
		die "Unknown command: '$command'. Use '$SCRIPT_NAME help'."
		;;
	esac
}

main "$@"
