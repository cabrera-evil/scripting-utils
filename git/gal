${BOLD}USAGE:${NC}
  $SCRIPT_NAME [GLOBAL_OPTIONS] COMMAND [COMMAND_OPTIONS]

${BOLD}COMMANDS:${NC}
  ${GREEN}scan${NC}      Scan workflow files and detect outdated actions
  ${GREEN}check${NC}     Check one action repo/current version pair
  ${GREEN}browse${NC}    Open a repository in browser
  ${GREEN}help${NC}      Show this help
  ${GREEN}version${NC}   Show version

${BOLD}GLOBAL OPTIONS:${NC}
  ${YELLOW}-q, --quiet${NC}              Minimize output
  ${YELLOW}-d, --debug${NC}              Enable debug output
  ${YELLOW}-h, --help${NC}               Show help
  ${YELLOW}-v, --version${NC}            Show version

${BOLD}SCAN OPTIONS:${NC}
  ${YELLOW}--path${NC} <dir>             Base directory to scan (default: .)
  ${YELLOW}--jobs${NC} <n>               Parallel tag lookups (default: 8 or GAL_JOBS)
  ${YELLOW}--include-major${NC}          Compare against latest stable across majors
  ${YELLOW}--update${NC}                 Rewrite outdated refs to recommended tags
  ${YELLOW}--open${NC}                   Open outdated action repos on recommended release tag

${BOLD}CHECK OPTIONS:${NC}
  ${YELLOW}--repo${NC} <owner/repo>      Action repository to check
  ${YELLOW}--current${NC} <tag>          Current version/tag in use (e.g. v4, optional)
  ${YELLOW}--include-major${NC}          Compare against latest stable across majors
  ${YELLOW}--open${NC}                   Open recommended release tag in browser

${BOLD}BROWSE OPTIONS:${NC}
  ${YELLOW}--repo${NC} <owner/repo>      Repository to open (default: detected from git remote)

${BOLD}EXAMPLES:${NC}
