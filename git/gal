  $SCRIPT_NAME scan --jobs 16
  $SCRIPT_NAME scan --update
  $SCRIPT_NAME scan --path /path/to/repo --open
  $SCRIPT_NAME check --repo actions/checkout --current v4
  $SCRIPT_NAME check --repo actions/checkout
  $SCRIPT_NAME check actions/checkout
  $SCRIPT_NAME check --repo actions/setup-node --current v3 --include-major
  $SCRIPT_NAME browse --repo actions/checkout
