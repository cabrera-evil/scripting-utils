}

cmd_version() {
	printf "%s %s\n" "$SCRIPT_NAME" "$VERSION"
}

cmd_scan() {
	require_command gh "gh (https://cli.github.com/)"
	require_command rg "ripgrep"

	local workflows_dir="$SCAN_PATH/.github/workflows"
	[[ -d "$workflows_dir" ]] || die "Workflows directory not found: $workflows_dir"

	local entries=()
	mapfile -t entries < <(rg -n --no-heading --color never -g '*.yml' -g '*.yaml' '^[[:space:]-]*uses:[[:space:]]*' "$workflows_dir" || true)

	((${#entries[@]} > 0)) || {
		warn "No action uses entries found in $workflows_dir"
		return 0
	}

	local entry file line content location target action_repo current_ref
	local -a parsed_entries=()
	declare -A unique_repos=()
	local parsed
	local total="${#entries[@]}" index=0
	for entry in "${entries[@]}"; do
		index=$((index + 1))
		IFS=':' read -r file line content <<<"$entry"
		location="${file}:${line}"
		show_scan_progress "Indexing" "$index" "$total" "$location"

		target=""
		if ! target="$(parse_uses_target_from_line "$content")"; then
			debug "Skipping unparsable line: $location"
			continue
		fi

		parsed="$(parse_action_repo_and_ref "$target" || true)"
		if [[ -z "$parsed" ]]; then
			debug "Skipping non-repo uses target '$target' at $location"
			continue
		fi
		IFS=$'\t' read -r action_repo current_ref <<<"$parsed"
		parsed_entries+=("$action_repo"$'\t'"$current_ref"$'\t'"$location"$'\t'"$target")
		unique_repos["$action_repo"]=1
	done
	finish_scan_progress

	local -a repo_list=()
	for action_repo in "${!unique_repos[@]}"; do
		repo_list+=("$action_repo")
	done
	prefetch_tags_parallel "${repo_list[@]}"

	total="${#parsed_entries[@]}"
	index=0
	local source_target
	for parsed in "${parsed_entries[@]}"; do
		index=$((index + 1))
		IFS=$'\t' read -r action_repo current_ref location source_target <<<"$parsed"
		show_scan_progress "Checking" "$index" "$total" "$location"
		compare_and_record "$action_repo" "$current_ref" "$location" "$source_target"
	done
	finish_scan_progress

	((${#SCAN_ROWS[@]} > 0)) || {
		warn "No supported action repo refs found"
		return 0
	}

	printf "\n%s\n" "${BOLD}Action Version Report${NC}"
	print_table "${SCAN_ROWS[@]}"
	printf "\nOutdated: %d | Unknown: %d | Total: %d\n" "$OUTDATED_COUNT" "$UNKNOWN_COUNT" "${#SCAN_ROWS[@]}"
	apply_pending_updates

	if ((OUTDATED_COUNT > 0)); then
		exit 3
	fi

	success "All detected actions are up-to-date for the selected policy."
}

cmd_check() {
	require_command gh "gh (https://cli.github.com/)"

	[[ -n "$CHECK_REPO" ]] || die "Missing required option: --repo <owner/repo>"
	if [[ -n "$CHECK_CURRENT" ]]; then
		compare_and_record "$CHECK_REPO" "$CHECK_CURRENT" "-"
	else
		local latest
		latest="$(latest_stable_tag_for_repo "$CHECK_REPO")"
		[[ -n "$latest" ]] || die "Could not determine a stable latest tag for '$CHECK_REPO'."
		SCAN_ROWS+=("$CHECK_REPO"$'\t'"-"$'\t'"$latest"$'\t'"latest"$'\t'"-")
		maybe_open_repo "$CHECK_REPO" "$latest"
	fi

	printf "\n%s\n" "${BOLD}Action Version Report${NC}"
	print_table "${SCAN_ROWS[@]}"

	if ((OUTDATED_COUNT > 0)); then
		exit 3
	fi
}

cmd_browse() {
	require_command gh "gh (https://cli.github.com/)"

	local repo
	repo="$(resolve_repo_for_browse)"
	log "Opening $repo"
	gh repo view "$repo" --web >/dev/null
	success "Opened $repo"
}

# ===================================
# ARGUMENT PARSING
# ===================================
parse_global_option() {
	case "$1" in
	-q | --quiet)
		QUIET=true
		return 0
		;;
	-d | --debug)
		DEBUG=true
		return 0
		;;
	-h | --help)
		cmd_help
		exit 0
		;;
	-v | --version)
		cmd_version
		exit 0
		;;
	esac
	return 1
}

parse_scan_arguments() {
	while [[ $# -gt 0 ]]; do
		if parse_global_option "$1"; then
			shift
			continue
		fi
		case "$1" in
		--path)
			SCAN_PATH="${2:?Missing value for $1}"
			shift 2
			;;
		--jobs)
			PARALLEL_JOBS="${2:?Missing value for $1}"
			shift 2
			;;
		--include-major)
			INCLUDE_MAJOR=true
			shift
			;;
		--update)
			UPDATE_FILES=true
			shift
			;;
		--open)
			OPEN_BROWSER=true
			shift
			;;
		-*)
			die "Unknown option for scan: $1"
			;;
		*)
			die "Unexpected argument for scan: $1"
			;;
		esac
	done
}

parse_check_arguments() {
	while [[ $# -gt 0 ]]; do
		if parse_global_option "$1"; then
			shift
			continue
		fi
		case "$1" in
		--repo)
			CHECK_REPO="${2:?Missing value for $1}"
			shift 2
			;;
		--current)
			CHECK_CURRENT="${2:?Missing value for $1}"
			shift 2
			;;
		--include-major)
			INCLUDE_MAJOR=true
			shift
			;;
		--open)
			OPEN_BROWSER=true
			shift
			;;
		-*)
			die "Unknown option for check: $1"
			;;
		*)
			if [[ -z "$CHECK_REPO" ]]; then
				CHECK_REPO="$1"
			elif [[ -z "$CHECK_CURRENT" ]]; then
				CHECK_CURRENT="$1"
			else
				die "Unexpected argument for check: $1"
			fi
			shift
			;;
		esac
	done
}

parse_browse_arguments() {
	while [[ $# -gt 0 ]]; do
		if parse_global_option "$1"; then
			shift
			continue
		fi
		case "$1" in
		--repo)
			BROWSE_REPO="${2:?Missing value for $1}"
			shift 2
			;;
		-*)
			die "Unknown option for browse: $1"
			;;
		*)
			die "Unexpected argument for browse: $1"
			;;
		esac
	done
}

# ===================================
# MAIN
# ===================================
main() {
	local command
	if [[ $# -eq 0 ]]; then
		command="scan"
	elif [[ "$1" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]]; then
		command="check"
	else
		command="$1"
		shift
	fi

	case "$command" in
	scan)
		parse_scan_arguments "$@"
		cmd_scan
		;;
	check)
		parse_check_arguments "$@"
		cmd_check
		;;
	browse)
		parse_browse_arguments "$@"
		cmd_browse
		;;
	help)
		cmd_help
		;;
	version)
		cmd_version
		;;
	*)
		die "Unknown command: '$command'. Use '$SCRIPT_NAME help'."
		;;
	esac
}

main "$@"
