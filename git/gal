#!/usr/bin/env bash
set -euo pipefail

# ===================================
# METADATA
# ===================================
SCRIPT_NAME="$(basename "$0")"
readonly SCRIPT_NAME
readonly VERSION="1.0.0"

# ===================================
# COLORS
# ===================================
if [[ -t 1 ]] && [[ "${TERM:-}" != "dumb" ]]; then
	readonly RED=$'\033[0;31m'
	readonly GREEN=$'\033[0;32m'
	readonly YELLOW=$'\033[0;33m'
	readonly BLUE=$'\033[0;34m'
	readonly MAGENTA=$'\033[0;35m'
	readonly BOLD=$'\033[1m'
	readonly NC=$'\033[0m'
else
	readonly RED='' GREEN='' YELLOW='' BLUE='' MAGENTA='' BOLD='' NC=''
fi

# ===================================
# CONFIGURATION
# ===================================
DEBUG=false
QUIET=false
INCLUDE_MAJOR=false
OPEN_BROWSER=false
UPDATE_FILES=false
PARALLEL_JOBS="${GAL_JOBS:-8}"
SCAN_PATH="."
CHECK_REPO=""
CHECK_CURRENT=""
BROWSE_REPO=""

# ===================================
# RUNTIME STATE
# ===================================
declare -A TAGS_CACHE=()
declare -A OPENED_REPOS=()
declare -A UPDATE_KEYS=()
declare -A RECOMMEND_CACHE=()
SCAN_ROWS=()
PENDING_UPDATES=()
OUTDATED_COUNT=0
UNKNOWN_COUNT=0

# ===================================
# LOGGING FUNCTIONS
# ===================================
log() {
	if [[ "$QUIET" != true ]]; then
		printf "${BLUE}▶${NC} %s\n" "$*"
	fi
}
warn() { printf "${YELLOW}⚠${NC} %s\n" "$*" >&2; }
error() { printf "${RED}✗${NC} %s\n" "$*" >&2; }
success() {
	if [[ "$QUIET" != true ]]; then
		printf "${GREEN}✓${NC} %s\n" "$*"
	fi
}
debug() {
	if [[ "$DEBUG" == true ]]; then
		printf "${MAGENTA}⚈${NC} DEBUG: %s\n" "$*" >&2
	fi
}
die() {
	error "$*"
	exit 1
}

# ===================================
# UTILITIES
# ===================================
require_command() {
	local cmd="$1" hint="${2:-$1}"
	command -v "$cmd" >/dev/null 2>&1 || die "'$cmd' not found. Install: $hint"
}

validate_positive_integer() {
	local value="$1" name="$2"
	[[ "$value" =~ ^[1-9][0-9]*$ ]] || die "Invalid $name: '$value' (must be positive integer)"
}

trim_quotes() {
	local value="$1"
	value="${value%\"}"
	value="${value#\"}"
	value="${value%\'}"
	value="${value#\'}"
	printf "%s" "$value"
}

is_semver_like_tag() {
	local tag="$1"
	[[ "$tag" =~ ^v?[0-9]+(\.[0-9]+)*$ ]]
}

major_of_tag() {
	local tag="${1#v}"
	printf "%s" "${tag%%.*}"
}

version_gt() {
	local a="${1#v}" b="${2#v}"
	[[ "$(printf '%s\n%s\n' "$a" "$b" | sort -V | tail -n1)" == "$a" && "$a" != "$b" ]]
}

latest_of_tags() {
	local best="" tag
	for tag in "$@"; do
		if [[ -z "$best" ]] || version_gt "$tag" "$best"; then
			best="$tag"
		fi
	done
	printf "%s" "$best"
}

detect_repo_from_git() {
	local url
	url="$(git config --get remote.origin.url || true)"
	[[ -z "$url" ]] && die "Cannot detect repository. Use --repo <owner/repo>."
	url="${url%.git}"
	if [[ "$url" =~ github\.com[:/]{1}([^/]+/[^/]+)$ ]]; then
		printf "%s" "${BASH_REMATCH[1]}"
	else
		die "Unsupported remote URL '$url'. Pass --repo <owner/repo>."
	fi
}

resolve_repo_for_browse() {
	if [[ -n "$BROWSE_REPO" ]]; then
		printf "%s" "$BROWSE_REPO"
		return
	fi
	if command -v gh >/dev/null 2>&1 &&
		gh repo view --json nameWithOwner -q .nameWithOwner >/dev/null 2>&1; then
		gh repo view --json nameWithOwner -q .nameWithOwner
		return
	fi
	detect_repo_from_git
}

fetch_tags_for_repo() {
	local repo="$1"
	if [[ -v "TAGS_CACHE[$repo]" ]]; then
		printf "%s" "${TAGS_CACHE[$repo]}"
		return
	fi

	local tags
	tags="$(gh api "repos/$repo/tags?per_page=100" --jq '.[].name' 2>/dev/null || true)"
	TAGS_CACHE["$repo"]="$tags"
	printf "%s" "$tags"
}

repo_cache_file() {
	local repo="$1"
	printf "%s" "${repo//\//__}.tags"
}

prefetch_tags_parallel() {
	local repos=("$@")
	((${#repos[@]} > 0)) || return 0
	validate_positive_integer "$PARALLEL_JOBS" "jobs"
	log "Prefetching tags for ${#repos[@]} repositories with $PARALLEL_JOBS workers..."

	local tmp_dir
	tmp_dir="$(mktemp -d)"

	local -a pids=()
	local repo file_path pid
	for repo in "${repos[@]}"; do
		file_path="$tmp_dir/$(repo_cache_file "$repo")"
		(
			gh api "repos/$repo/tags?per_page=100" --jq '.[].name' 2>/dev/null || true
		) >"$file_path" &
		pids+=("$!")

		if ((${#pids[@]} >= PARALLEL_JOBS)); then
			pid="${pids[0]}"
			wait "$pid" || true
			pids=("${pids[@]:1}")
		fi
	done

	for pid in "${pids[@]}"; do
		wait "$pid" || true
	done

	for repo in "${repos[@]}"; do
		file_path="$tmp_dir/$(repo_cache_file "$repo")"
		TAGS_CACHE["$repo"]="$(cat "$file_path" 2>/dev/null || true)"
	done
	rm -rf "$tmp_dir"
}

fetch_release_tag_for_repo() {
	local repo="$1"
	gh release view --repo "$repo" --json tagName -q .tagName 2>/dev/null || true
}

latest_recommended_for_ref() {
	local repo="$1" current_ref="$2" include_major="$3"
	local cache_key="${repo}|${current_ref}|${include_major}"
	if [[ -v "RECOMMEND_CACHE[$cache_key]" ]]; then
		printf "%s" "${RECOMMEND_CACHE[$cache_key]}"
		return
	fi

	local tags
	tags="$(fetch_tags_for_repo "$repo")"
	[[ -z "$tags" ]] && {
		RECOMMEND_CACHE["$cache_key"]=""
		printf ""
		return
	}

	local stable_tags=() tag
	while IFS= read -r tag; do
		[[ -z "$tag" ]] && continue
		is_semver_like_tag "$tag" || continue
		stable_tags+=("$tag")
	done <<<"$tags"

	((${#stable_tags[@]} > 0)) || {
		RECOMMEND_CACHE["$cache_key"]=""
		printf ""
		return
	}

	if [[ "$include_major" == true ]]; then
		local latest
		latest="$(latest_of_tags "${stable_tags[@]}")"
		RECOMMEND_CACHE["$cache_key"]="$latest"
		printf "%s" "$latest"
		return
	fi

	if ! is_semver_like_tag "$current_ref"; then
		RECOMMEND_CACHE["$cache_key"]=""
		printf ""
		return
	fi

	local major
	major="$(major_of_tag "$current_ref")"
	local same_major=()
	for tag in "${stable_tags[@]}"; do
		[[ "$(major_of_tag "$tag")" == "$major" ]] && same_major+=("$tag")
	done

	((${#same_major[@]} > 0)) || {
		RECOMMEND_CACHE["$cache_key"]=""
		printf ""
		return
	}

	local latest
	latest="$(latest_of_tags "${same_major[@]}")"
	RECOMMEND_CACHE["$cache_key"]="$latest"
	printf "%s" "$latest"
}

latest_stable_tag_for_repo() {
	local repo="$1"
	local tags
	tags="$(fetch_tags_for_repo "$repo")"

	local stable_tags=() tag
	while IFS= read -r tag; do
		[[ -z "$tag" ]] && continue
		is_semver_like_tag "$tag" || continue
		stable_tags+=("$tag")
	done <<<"$tags"

	if ((${#stable_tags[@]} == 0)); then
		local release_tag
		release_tag="$(fetch_release_tag_for_repo "$repo")"
		if is_semver_like_tag "$release_tag"; then
			printf "%s" "$release_tag"
			return
		fi
		printf ""
		return
	fi

	latest_of_tags "${stable_tags[@]}"
}

parse_uses_target_from_line() {
	local line="$1"
	if [[ "$line" =~ uses:[[:space:]]*([^[:space:]#]+) ]]; then
		trim_quotes "${BASH_REMATCH[1]}"
		return 0
	fi
	return 1
}

parse_action_repo_and_ref() {
	local target="$1"

	if [[ "$target" == ./* ]] || [[ "$target" == docker://* ]]; then
		return 1
	fi

	[[ "$target" == *@* ]] || return 1

	local left="${target%@*}"
	local ref="${target##*@}"
	local owner="${left%%/*}"
	local rest="${left#*/}"
	local repo_name="${rest%%/*}"
	local repo="${owner}/${repo_name}"

	[[ "$repo" =~ ^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$ ]] || return 1

	printf "%s\t%s" "$repo" "$ref"
}

pad_right() {
	local s="$1" width="$2"
	printf "%-*s" "$width" "$s"
}

show_scan_progress() {
	local phase="$1" current="$2" total="$3" location="$4"
	[[ "$QUIET" == true ]] && return 0
	if [[ -t 1 ]]; then
		printf "\r${BLUE}▶${NC} %s %d/%d: %s\033[K" "$phase" "$current" "$total" "$location"
	else
		printf "%s %d/%d: %s\n" "$phase" "$current" "$total" "$location"
	fi
}

finish_scan_progress() {
	[[ "$QUIET" == true ]] && return 0
	[[ -t 1 ]] && printf "\n"
}

print_table() {
	local rows=("$@")
	local headers=("ACTION" "CURRENT" "RECOMMENDED" "STATUS" "LOCATION")
	local w1=${#headers[0]} w2=${#headers[1]} w3=${#headers[2]} w4=${#headers[3]} w5=${#headers[4]}
	local row c1 c2 c3 c4 c5

	for row in "${rows[@]}"; do
		IFS=$'\t' read -r c1 c2 c3 c4 c5 <<<"$row"
		((${#c1} > w1)) && w1=${#c1}
		((${#c2} > w2)) && w2=${#c2}
		((${#c3} > w3)) && w3=${#c3}
		((${#c4} > w4)) && w4=${#c4}
		((${#c5} > w5)) && w5=${#c5}
	done

	printf "%s  %s  %s  %s  %s\n" \
		"$(pad_right "${headers[0]}" "$w1")" \
		"$(pad_right "${headers[1]}" "$w2")" \
		"$(pad_right "${headers[2]}" "$w3")" \
		"$(pad_right "${headers[3]}" "$w4")" \
		"$(pad_right "${headers[4]}" "$w5")"

	printf "%s  %s  %s  %s  %s\n" \
		"$(pad_right "$(printf '%*s' "$w1" '' | tr ' ' '-')" "$w1")" \
		"$(pad_right "$(printf '%*s' "$w2" '' | tr ' ' '-')" "$w2")" \
		"$(pad_right "$(printf '%*s' "$w3" '' | tr ' ' '-')" "$w3")" \
		"$(pad_right "$(printf '%*s' "$w4" '' | tr ' ' '-')" "$w4")" \
		"$(pad_right "$(printf '%*s' "$w5" '' | tr ' ' '-')" "$w5")"

	for row in "${rows[@]}"; do
		IFS=$'\t' read -r c1 c2 c3 c4 c5 <<<"$row"
		printf "%s  %s  %s  %s  %s\n" \
			"$(pad_right "$c1" "$w1")" \
			"$(pad_right "$c2" "$w2")" \
			"$(pad_right "$c3" "$w3")" \
			"$(pad_right "$c4" "$w4")" \
			"$(pad_right "$c5" "$w5")"
	done
}

maybe_open_repo() {
	local repo="$1"
	local recommended="${2:-}"
	[[ "$OPEN_BROWSER" == true ]] || return 0
	local key="$repo"
	if [[ -n "$recommended" ]]; then
		key="${repo}@${recommended}"
	fi
	[[ -v "OPENED_REPOS[$key]" ]] && return 0
	OPENED_REPOS["$key"]=1

	if [[ -n "$recommended" ]]; then
		local release_url="https://github.com/$repo/releases/tag/$recommended"
		local tree_url="https://github.com/$repo/tree/$recommended"
		if gh browse "$release_url" >/dev/null 2>&1; then
			debug "Opened '$repo' release tag '$recommended' in browser"
			return 0
		fi
		if gh browse "$tree_url" >/dev/null 2>&1; then
			debug "Opened '$repo' tag tree '$recommended' in browser"
			return 0
		fi
		warn "Could not open '$repo' tag '$recommended'. Falling back to repo page."
	fi

	if gh repo view "$repo" --web >/dev/null 2>&1; then
		debug "Opened '$repo' in browser"
	else
		warn "Could not open '$repo' in browser"
	fi
}

queue_update() {
	local original_target="$1" recommended="$2" location="$3"
	[[ "$UPDATE_FILES" == true ]] || return 0
	[[ "$location" == *:* ]] || return 0
	[[ "$recommended" != "-" ]] || return 0
	[[ "$original_target" == *@* ]] || return 0

	local file="${location%:*}"
	local line="${location##*:}"
	[[ "$line" =~ ^[0-9]+$ ]] || return 0

	local key="${file}:${line}"
	[[ -v "UPDATE_KEYS[$key]" ]] && return 0
	UPDATE_KEYS["$key"]=1

	local old_ref="$original_target"
	local new_ref="${original_target%@*}@${recommended}"
	[[ "$old_ref" != "$new_ref" ]] || return 0
	PENDING_UPDATES+=("$file"$'\t'"$line"$'\t'"$old_ref"$'\t'"$new_ref")
}

replace_literal_at_line() {
	local file="$1" line="$2" old="$3" new="$4"
	local tmp_file
	tmp_file="$(mktemp)"

	if awk -v n="$line" -v old="$old" -v new="$new" '
	BEGIN { changed = 0 }
	NR == n {
		idx = index($0, old)
		if (idx > 0) {
			$0 = substr($0, 1, idx - 1) new substr($0, idx + length(old))
			changed = 1
		}
	}
	{ print }
	END { exit(changed ? 0 : 1) }
	' "$file" >"$tmp_file"; then
		chmod --reference="$file" "$tmp_file"
		mv "$tmp_file" "$file"
		return 0
	fi

	rm -f "$tmp_file"
	return 1
}

apply_pending_updates() {
	[[ "$UPDATE_FILES" == true ]] || return 0
	((${#PENDING_UPDATES[@]} > 0)) || {
		log "No outdated refs eligible for --update."
		return 0
	}

	local applied=0 failed=0 entry file line old_ref new_ref
	log "Applying ${#PENDING_UPDATES[@]} update(s) to workflow files..."
	for entry in "${PENDING_UPDATES[@]}"; do
		IFS=$'\t' read -r file line old_ref new_ref <<<"$entry"
		if replace_literal_at_line "$file" "$line" "$old_ref" "$new_ref"; then
			applied=$((applied + 1))
			debug "Updated $file:$line ($old_ref -> $new_ref)"
		else
			failed=$((failed + 1))
			warn "Could not update $file:$line ($old_ref -> $new_ref)"
		fi
	done

	if ((failed > 0)); then
		warn "Applied $applied update(s), $failed failed."
	else
		success "Applied $applied update(s)."
	fi
}

compare_and_record() {
	local action_repo="$1" current_ref="$2" location="$3" source_target="${4:-}"
	local recommended status
	recommended="$(latest_recommended_for_ref "$action_repo" "$current_ref" "$INCLUDE_MAJOR")"

	if [[ -z "$recommended" ]]; then
		status="unknown"
		UNKNOWN_COUNT=$((UNKNOWN_COUNT + 1))
		recommended="-"
	elif [[ "$current_ref" == "$recommended" ]]; then
		status="up-to-date"
	else
		status="outdated"
		OUTDATED_COUNT=$((OUTDATED_COUNT + 1))
		queue_update "$source_target" "$recommended" "$location"
		maybe_open_repo "$action_repo" "$recommended"
	fi

	SCAN_ROWS+=("$action_repo"$'\t'"$current_ref"$'\t'"$recommended"$'\t'"$status"$'\t'"$location")
}

